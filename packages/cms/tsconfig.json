{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "module": "Preserve",
    "outDir": "dist",
    "sourceMap": true,
    "declaration": true,
    "composite": true,
    "declarationMap": true,
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "include": [
    "sanity.config.ts",
    "sanity.cli.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "generated/**/*.ts"
  ]
}

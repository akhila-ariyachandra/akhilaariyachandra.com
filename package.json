{
  "name": "akhilaariyachandra.com",
  "version": "2.0.0",
  "description": "The code for akhilaariyachandra.com",
  "repository": "https://github.com/akhila-ariyachandra/akhilaariyachandra.com.git",
  "author": "Akhila Ariyachandra <akhila_ariyachandra@live.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "dev:prepare": "node src/scripts/pre-build.js",
    "lint": "next lint",
    "analyze": "cross-env ANALYZE=true next build",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && node src/scripts/pre-build.js && next build",
    "start": "next start",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,mdx,yaml,scss,prisma}\"",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate-create-only": "prisma migrate dev --create-only",
    "prisma:generate": "prisma generate",
    "prisma:reset": "prisma migrate reset",
    "postinstall": "prisma generate"
  },
  "prettier": {
    "endOfLine": "lf",
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5"
  },
  "resolutions": {
    "styled-components": "^5"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "dependencies": {
    "@badrap/bar-of-progress": "^0.1.2",
    "@fec/remark-a11y-emoji": "^3.1.0",
    "@next/bundle-analyzer": "^11.0.0",
    "@prisma/client": "^2.25.0",
    "@silvenon/remark-smartypants": "^1.0.0",
    "@splitbee/web": "^0.2.4",
    "axios": "^0.21.1",
    "dayjs": "^1.10.4",
    "feed": "^4.2.2",
    "gray-matter": "^4.0.2",
    "mdx-embed": "^0.0.19",
    "nanoid": "^3.1.22",
    "next": "^11.0.0",
    "next-mdx-remote": "^3.0.1",
    "next-pwa": "^5.2.21",
    "next-seo": "^4.25.1",
    "next-themes": "^0.0.14",
    "parse-numeric-range": "^1.2.0",
    "preact": "^10.5.13",
    "prism-react-renderer": "^1.2.0",
    "querystring": "^0.2.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-icons": "^4.2.0",
    "react-lazyload": "^3.2.0",
    "react-query": "^3.17.2",
    "react-retro-hit-counter": "^1.0.1",
    "react-tooltip": "^4.2.21",
    "reading-time": "^1.3.0",
    "remark-external-links": "^8.0.0",
    "remark-slug": "^6.0.0",
    "sass": "^1.35.1",
    "styled-components": "^5.3.0",
    "yaml": "^1.10.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.4.0",
    "@types/node": "^15.12.1",
    "@types/react": "^17.0.9",
    "autoprefixer": "^10.2.5",
    "babel-plugin-styled-components": "^1.12.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.28.0",
    "eslint-config-next": "^11.0.0",
    "minify-xml": "^2.5.0",
    "next-compose-plugins": "^2.2.1",
    "postcss": "^8.3.5",
    "prettier": "^2.2.1",
    "prettier-plugin-prisma": "^0.12.1",
    "prettier-plugin-tailwind": "^2.2.10",
    "prisma": "^2.25.0",
    "tailwindcss": "^2.2.0",
    "typescript": "^4.3.4"
  },
  "optionalDependencies": {
    "terser-webpack-plugin": "^5.1.3"
  }
}
